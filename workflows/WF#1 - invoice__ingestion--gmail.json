    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\nconst outputItems = [];\n\nfor (\n  let itemIndex = 0;\n  itemIndex < inputItems.length;\n  itemIndex++\n) {\n  const item =\n    inputItems[itemIndex];\n\n  const binaryFiles =\n    item.binary ?? {};\n\n  const pdfFiles = [];\n\n  for (\n    const [binaryKey, file]\n    of Object.entries(binaryFiles)\n  ) {\n    const fileName =\n      String(file.fileName ?? '');\n\n    const mimeType =\n      String(file.mimeType ?? '');\n\n    const fileExtension =\n      String(file.fileExtension ?? '');\n\n    const isPdf =\n      mimeType.toLowerCase() ===\n        'application/pdf' ||\n      fileExtension.toLowerCase() ===\n        'pdf' ||\n      fileName.toLowerCase().endsWith(\n        '.pdf'\n      );\n\n    if (!isPdf) {\n      continue;\n    }\n\n    pdfFiles.push({\n      binaryKey,\n      file,\n    });\n  }\n\n  for (\n    let attachmentIndex = 0;\n    attachmentIndex < pdfFiles.length;\n    attachmentIndex++\n  ) {\n    const {\n      binaryKey,\n      file,\n    } = pdfFiles[attachmentIndex];\n\n    outputItems.push({\n      json: {\n        email_message_id:\n          item.json.id ?? '',\n\n        email_thread_id:\n          item.json.threadId ?? '',\n\n        sender_email:\n          item.json.from?.value?.[0]\n            ?.address ?? '',\n\n        sender_name:\n          item.json.from?.value?.[0]\n            ?.name ?? '',\n\n        email_subject:\n          item.json.subject ?? '',\n\n        received_at:\n          item.json.date ?? '',\n\n        email_message_header_id:\n          item.json.messageId ?? '',\n\n        source_binary_key:\n          binaryKey,\n\n        file_name:\n          file.fileName ?? '',\n\n        mime_type:\n          file.mimeType ?? '',\n\n        file_extension:\n          file.fileExtension ?? '',\n\n        attachment_index:\n          attachmentIndex,\n\n        attachment_count:\n          pdfFiles.length,\n\n        status:\n          'received',\n      },\n\n      binary: {\n        invoice_file:\n          file,\n      },\n\n      pairedItem: {\n        item:\n          itemIndex,\n      },\n    });\n  }\n}\n\nreturn outputItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -160,
        -112
      ],
      "id": "9816640b-c730-4fa1-9ca8-f750899b1141",
