      "executeOnce": false
    },
    {
      "parameters": {
        "jsCode": "const data = $json;\n\nconst emailMessageId = String(data.email_message_id ?? '').trim();\nconst attachmentIndex = Number(data.attachment_index ?? 0);\n\nif (!emailMessageId) {\n  throw new Error('EMAIL_MESSAGE_ID_MISSING');\n}\n\nconst paddedAttachmentIndex = String(attachmentIndex).padStart(2, '0');\n\nconst processingId =\n  `DOC-${emailMessageId}-${paddedAttachmentIndex}`;\n\nconst originalFileName =\n  String(data.file_name ?? 'invoice.pdf').trim();\n\nconst fileExtension =\n  String(data.file_extension ?? 'pdf')\n    .toLowerCase()\n    .replace(/[^a-z0-9]/g, '') || 'pdf';\n\nconst baseFileName = originalFileName\n  .replace(/\\.[^/.]+$/, '')\n  .normalize('NFKD')\n  .replace(/[^\\w\\s-]/g, '')\n  .trim()\n  .replace(/\\s+/g, '-')\n  .replace(/-+/g, '-')\n  .toLowerCase()\n  .slice(0, 80);\n\nconst safeBaseFileName =\n  baseFileName || 'invoice-document';\n\nconst storageFileName =\n  `${processingId}__${safeBaseFileName}.${fileExtension}`;\n\nreturn {\n  json: {\n    ...data,\n    processing_id: processingId,\n    original_file_name: originalFileName,\n    storage_file_name: storageFileName,\n    processing_started_at: new Date().toISOString(),\n    workflow_name: 'invoice__ingestion--gmail',\n    workflow_version: '1.0.0',\n    status: 'received'\n  },\n  binary: $binary\n};"
      },
