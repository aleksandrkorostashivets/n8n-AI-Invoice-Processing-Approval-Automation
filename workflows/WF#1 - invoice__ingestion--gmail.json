n      '',\n\n    previous_status:\n      existingStatus,\n\n    status:\n      'extraction_pending',\n\n    processing_resumed:\n      true,\n\n    resume_stage:\n      'extraction',\n\n    resume_reason:\n      state.duplicate_reason ||\n      'existing_incomplete_record',\n\n    resume_started_at:\n      resumeStartedAt,\n\n    extraction_started_at:\n      resumeStartedAt,\n  },\n\n  binary: {\n    invoice_file: {\n      ...$binary.invoice_file,\n\n      fileName:\n        existing.storage_file_name ||\n        state.storage_file_name ||\n        $binary.invoice_file.fileName,\n    },\n  },\n};"
