minal_record';\n  } else {\n    processingRoute =\n      'error';\n\n    duplicateReason =\n      `unsupported_existing_status:${existingStatus || 'empty'}`;\n  }\n}\n\nreturn {\n  json: {\n    ...sourceItem.json,\n\n    existing_record:\n      recordExists\n        ? lookupResult\n        : null,\n\n    record_exists:\n      recordExists,\n\n    existing_status:\n      existingStatus,\n\n    processing_route:\n      processingRoute,\n\n    duplicate_reason:\n      duplicateReason,\n\n    duplicate_checked_at:\n      new Date().toISOString(),\n  },\n\n  binary: {\n    invoice_file:\n      sourceItem.binary.invoice_file,\n  },\n};"
