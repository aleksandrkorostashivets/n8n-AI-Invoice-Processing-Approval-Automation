      "parameters": {
        "jsCode": "const archived =\n  $('invoice__rejection--normalize-archive-result').item.json;\n\nconst sheetResult =\n  $json;\n\nconst returnedStatus =\n  String(sheetResult.status || '')\n    .trim()\n    .toLowerCase();\n\nif (\n  returnedStatus &&\n  returnedStatus !== 'rejected'\n) {\n  throw new Error(\n    `REJECTION_REGISTRY_STATUS_MISMATCH: expected rejected, received ${returnedStatus}`\n  );\n}\n\nreturn {\n  json: {\n    ...archived,\n\n    status:\n      'rejected',\n\n    approval_decision:\n      'rejected',\n\n    registry_updated:\n      true,\n\n    registry_row_number:\n      sheetResult.row_number ??\n      sheetResult.rowNumber ??\n      archived.row_number ??\n      null,\n\n    rejection_completed:\n      true,\n\n    rejection_completed_at:\n      new Date().toISOString(),\n  },\n};"
      },
