      "parameters": {
        "jsCode": "const prepared =\n  $('invoice__rejection--prepare-file').item.json;\n\nconst driveResult =\n  $json;\n\nconst driveFileId =\n  driveResult.id ||\n  prepared.drive_file_id;\n\nif (!driveFileId) {\n  throw new Error(\n    `REJECTION_MOVE_RESULT_INVALID: ${prepared.processing_id}`\n  );\n}\n\nconst archivedAt =\n  new Date().toISOString();\n\nreturn {\n  json: {\n    ...prepared,\n\n    status:\n      'rejected',\n\n    approval_decision:\n      'rejected',\n\n    drive_file_id:\n      driveFileId,\n\n    drive_file_url:\n      `https://drive.google.com/file/d/${driveFileId}/view`,\n\n    rejection_archived:\n      true,\n\n    rejection_archive_folder:\n      '04_Rejected',\n\n    rejection_archived_at:\n      archivedAt,\n\n    rejection_archive_result: {\n      file_id:\n        driveFileId,\n\n      file_name:\n        driveResult.name ||\n        prepared.storage_file_name ||\n        prepared.file_name ||\n        '',\n\n      mime_type:\n        driveResult.mimeType ||\n        'application/pdf',\n\n      folder:\n        '04_Rejected',\n    },\n  },\n};"
      },
