    {
      "parameters": {
        "jsCode": "const invoice = $json;\n\nconst processingId =\n  String(invoice.processing_id || '').trim();\n\nif (!processingId) {\n  throw new Error(\n    'REJECTION_PROCESSING_ID_MISSING'\n  );\n}\n\nconst driveFileUrl =\n  String(invoice.drive_file_url || '').trim();\n\nlet driveFileId =\n  String(invoice.drive_file_id || '').trim();\n\nif (!driveFileId && driveFileUrl) {\n  const match =\n    driveFileUrl.match(\n      /\\/file\\/d\\/([^/]+)/\n    );\n\n  if (match?.[1]) {\n    driveFileId = match[1];\n  }\n}\n\nif (!driveFileId) {\n  throw new Error(\n    `REJECTION_DRIVE_FILE_ID_MISSING: ${processingId}`\n  );\n}\n\nconst callbackAction =\n  String(invoice.callback_action || '')\n    .trim()\n    .toLowerCase();\n\nlet rejectionStage =\n  'unknown';\n\nif (callbackAction === 'reject') {\n  rejectionStage =\n    'manual_review';\n}\n\nif (callbackAction === 'approval_reject') {\n  rejectionStage =\n    'final_approval';\n}\n\nconst rejectedAt =\n  invoice.rejected_at ||\n  invoice.final_decision_at ||\n  invoice.processed_at ||\n  new Date().toISOString();\n\nreturn {\n  json: {\n    ...invoice,\n\n    drive_file_id:\n      driveFileId,\n\n    rejection_stage:\n      rejectionStage,\n\n    rejection_target_folder:\n      '04_Rejected',\n\n    rejected_at:\n      rejectedAt,\n\n    rejection_archive_started_at:\n      new Date().toISOString(),\n  },\n};"
      },
