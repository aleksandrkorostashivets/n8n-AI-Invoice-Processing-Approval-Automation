    {
      "parameters": {
        "jsCode": "const sourceItem =\n  $('invoice__trigger--subworkflow').first();\n\nif (!sourceItem) {\n  throw new Error('MANUAL_REVIEW_SOURCE_NOT_FOUND');\n}\n\nconst invoice = sourceItem.json;\n\nconst normalizeText = (value) => {\n  if (value === null || value === undefined) {\n    return '';\n  }\n\n  return String(value)\n    .replace(/\\s+/g, ' ')\n    .trim();\n};\n\nconst normalizeUpper = (value) => {\n  return normalizeText(value).toUpperCase();\n};\n\nconst normalizeBoolean = (value) => {\n  if (typeof value === 'boolean') {\n    return value;\n  }\n\n  return [\n    'true',\n    '1',\n    'yes',\n    'active'\n  ].includes(\n    normalizeText(value).toLowerCase()\n  );\n};\n\nconst normalizeAmount = (value) => {\n  if (\n    value === null ||\n    value === undefined ||\n    value === ''\n  ) {\n    return null;\n  }\n\n  const normalized = String(value)\n    .replace(/\\s/g, '')\n    .replace(/,/g, '');\n\n  const number = Number(normalized);\n\n  return Number.isFinite(number)\n    ? number\n    : null;\n};\n\nconst invoiceAmount =\n  normalizeAmount(invoice.total_amount);\n\nconst invoiceCurrency =\n  normalizeUpper(invoice.currency);\n\nconst rules = $input.all()\n  .map(item => item.json)\n  .filter(rule => {\n    if (!rule?.rule_id) {\n      return false;\n    }\n\n    const minAmount =\n      normalizeAmount(rule.min_amount);\n\n    const maxAmount =\n      normalizeAmount(rule.max_amount);\n\n    const currencyMatches =\n      normalizeUpper(rule.currency) ===\n      invoiceCurrency;\n\n    const active =\n      normalizeBoolean(rule.is_active);\n\n    const amountMatches =\n      invoiceAmount !== null &&\n      minAmount !== null &&\n      maxAmount !== null &&\n      invoiceAmount >= minAmount &&\n      invoiceAmount <= maxAmount;\n\n    return (\n      currencyMatches &&\n      active &&\n      amountMatches\n    );\n  });\n\nrules.sort((a, b) => {\n  const aRange =\n    normalizeAmount(a.max_amount) -\n    normalizeAmount(a.min_amount);\n\n  const bRange =\n    normalizeAmount(b.max_amount) -\n    normalizeAmount(b.min_amount);\n\n  return aRange - bRange;\n});\n\nconst selectedRule =\n  rules.length > 0\n    ? rules[0]\n    : null;\n\nconst resolvedManagerId =\n  normalizeText(selectedRule?.manager_id) ||\n  normalizeText(invoice.manager_id);\n\nif (!resolvedManagerId) {\n  throw new Error(\n    `MANAGER_ID_NOT_FOUND: ${invoice.processing_id}`\n  );\n}\n\nreturn [\n  {\n    json: {\n      ...invoice,\n\n      manager_id: resolvedManagerId,\n      approval_rule_id:\n        selectedRule?.rule_id ?? null,\n      approval_rule_count:\n        rules.length,\n\n      manager_resolved_at:\n        new Date().toISOString()\n    },\n\n    binary: sourceItem.binary\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -416,
        -64
      ],
      "id": "4783dbea-471f-4cfb-9615-46fcbe09ee3b",
      "name": "invoice__manager--resolve-approval-rule",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const invoice = $json;\n\nconst escapeHtml = (value) => {\n  return String(value ?? '')\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;');\n};\n\nconst formatAmount = (value) => {\n  const amount = Number(value);\n\n  if (!Number.isFinite(amount)) {\n    return 'Not available';\n  }\n\n  return new Intl.NumberFormat(\n    'en-US',\n    {\n      minimumFractionDigits: 2,\n      maximumFractionDigits: 2\n    }\n  ).format(amount);\n};\n\nconst riskLabels = {\n  iban_mismatch:\n    'Bank details do not match the vendor record',\n  sender_email_mismatch:\n    'Sender email does not match the vendor record',\n  vendor_not_found:\n    'Vendor was not found in the approved vendor database',\n  vendor_inactive:\n    'Vendor is inactive',\n  vendor_tax_id_not_unique:\n    'Multiple vendors use the same Tax ID',\n  duplicate_invoice:\n    'Possible duplicate invoice detected',\n  invoice_number_reused_amount_mismatch:\n    'Invoice number already exists with a different amount',\n  total_amount_mismatch:\n    'Invoice totals are inconsistent',\n  invalid_iban_format:\n    'IBAN format is invalid',\n  low_extraction_confidence:\n    'Document extraction confidence is low'\n};\n\nconst risks = Array.isArray(invoice.risk_flags)\n  ? invoice.risk_flags\n  : [];\n\nconst riskText = risks.length > 0\n  ? risks\n      .map(flag => {\n        const label =\n          riskLabels[flag] ||\n          flag.replace(/_/g, ' ');\n\n        return `• ${escapeHtml(label)}`;\n      })\n      .join('\\n')\n  : '• Manual review was requested';\n\nconst invoiceIban =\n  escapeHtml(invoice.iban || 'Not found');\n\nconst registeredIban =\n  escapeHtml(\n    invoice.registered_iban ||\n    'Not available'\n  );\n\nconst message = [\n  '⚠️ <b>Invoice requires manual review</b>',\n  '',\n  `<b>Supplier:</b> ${escapeHtml(invoice.vendor_name)}`,\n  `<b>Invoice:</b> ${escapeHtml(invoice.invoice_number)}`,\n  `<b>Amount:</b> ${escapeHtml(invoice.currency)} ${formatAmount(invoice.total_amount)}`,\n  `<b>Invoice date:</b> ${escapeHtml(invoice.invoice_date)}`,\n  `<b>Due date:</b> ${escapeHtml(invoice.due_date)}`,\n  `<b>Sender:</b> ${escapeHtml(invoice.sender_email)}`,\n  '',\n  '<b>Detected risks:</b>',\n  riskText,\n  '',\n  '<b>Bank verification:</b>',\n  `<b>Invoice IBAN:</b> <code>${invoiceIban}</code>`,\n  `<b>Registered IBAN:</b> <code>${registeredIban}</code>`,\n  '',\n  `<a href=\"${escapeHtml(invoice.drive_file_url)}\">Open invoice PDF</a>`,\n  '',\n  `<b>Processing ID:</b> <code>${escapeHtml(invoice.processing_id)}</code>`\n].join('\\n');\n\nconst reviewCallback =\n  `review|${invoice.processing_id}`;\n\nconst rejectCallback =\n  `reject|${invoice.processing_id}`;\n\nif (reviewCallback.length > 64) {\n  throw new Error('REVIEW_CALLBACK_TOO_LONG');\n}\n\nif (rejectCallback.length > 64) {\n  throw new Error('REJECT_CALLBACK_TOO_LONG');\n}\n\nreturn {\n  json: {\n    ...invoice,\n\n    telegram_message: message,\n    review_callback_data: reviewCallback,\n    reject_callback_data: rejectCallback,\n\n    manual_review_prepared_at:\n      new Date().toISOString()\n  },\n\n  binary: $binary\n};"
      },
