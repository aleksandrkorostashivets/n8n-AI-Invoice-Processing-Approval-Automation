    {
      "parameters": {
        "jsCode": "const sourceItem =\n  $('invoice__message--prepare-manual-review').item;\n\nif (!sourceItem) {\n  throw new Error(\n    'MANUAL_REVIEW_MESSAGE_SOURCE_NOT_FOUND'\n  );\n}\n\nconst telegramResponse =\n  $json.result ?? $json;\n\nconst telegramMessageId =\n  telegramResponse.message_id ??\n  telegramResponse.messageId ??\n  null;\n\nconst telegramChatId =\n  telegramResponse.chat?.id ??\n  sourceItem.json.manager_id ??\n  null;\n\nif (!telegramMessageId) {\n  throw new Error(\n    'TELEGRAM_MESSAGE_ID_MISSING'\n  );\n}\n\nif (!telegramChatId) {\n  throw new Error(\n    'TELEGRAM_CHAT_ID_MISSING'\n  );\n}\n\nreturn {\n  json: {\n    ...sourceItem.json,\n\n    status: 'manual_review_pending',\n    approval_decision: 'pending',\n\n    manager_id:\n      String(telegramChatId),\n\n    telegram_message_id:\n      telegramMessageId,\n\n    telegram_chat_id:\n      String(telegramChatId),\n\n    manual_review_requested_at:\n      new Date().toISOString()\n  },\n\n  binary: sourceItem.binary\n};"
      },
