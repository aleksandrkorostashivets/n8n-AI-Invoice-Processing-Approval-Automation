    {
      "parameters": {
        "jsCode": "const prepared =\n  $('invoice__accounting--prepare-entry').item.json;\n\nconst sheetResult = $json;\n\nconst accountingEntryId =\n  sheetResult.accounting_entry_id ??\n  prepared.accounting_entry_id ??\n  '';\n\nif (!accountingEntryId) {\n  throw new Error(\n    'ACCOUNTING_ENTRY_ID_MISSING_AFTER_EXPORT'\n  );\n}\n\nconst completedAt =\n  sheetResult.exported_at ??\n  prepared.accounting_exported_at ??\n  new Date().toISOString();\n\nreturn {\n  json: {\n    ...prepared,\n\n    status: 'accounting_exported',\n    accounting_exported: true,\n\n    accounting_entry_id:\n      accountingEntryId,\n\n    accounting_exported_at:\n      completedAt,\n\n    accounting_sheet_row_number:\n      sheetResult.row_number ??\n      sheetResult.rowNumber ??\n      null,\n\n    accounting_export_result: {\n      accounting_entry_id:\n        accountingEntryId,\n\n      invoice_id:\n        sheetResult.invoice_id ??\n        prepared.invoice_id,\n\n      approval_status:\n        sheetResult.approval_status ??\n        prepared.accounting_approval_status ??\n        'approved',\n\n      exported_at:\n        completedAt,\n    },\n  },\n};"
      },
