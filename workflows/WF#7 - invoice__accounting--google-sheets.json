    {
      "parameters": {
        "jsCode": "const invoice = $json;\n\nconst requiredFields = [\n  'invoice_id',\n  'processing_id',\n  'vendor_id',\n  'vendor_name',\n  'invoice_number',\n  'invoice_date',\n  'due_date',\n  'currency',\n  'total_amount',\n  'approval_decision',\n  'approved_at',\n  'drive_file_url'\n];\n\nconst missingFields = requiredFields.filter(\n  field => {\n    const value = invoice[field];\n\n    return (\n      value === null ||\n      value === undefined ||\n      value === ''\n    );\n  }\n);\n\nif (missingFields.length > 0) {\n  throw new Error(\n    `ACCOUNTING_FIELDS_MISSING: ${missingFields.join(', ')}`\n  );\n}\n\nconst totalAmount =\n  Number(\n    String(invoice.total_amount)\n      .replace(/\\s/g, '')\n      .replace(/,/g, '')\n  );\n\nif (\n  !Number.isFinite(totalAmount) ||\n  totalAmount <= 0\n) {\n  throw new Error(\n    `ACCOUNTING_TOTAL_INVALID: ${invoice.total_amount}`\n  );\n}\n\nconst normalizeRisks = (value) => {\n  if (Array.isArray(value)) {\n    return value\n      .map(String)\n      .map(item => item.trim())\n      .filter(Boolean);\n  }\n\n  return String(value ?? '')\n    .split(',')\n    .map(item => item.trim())\n    .filter(Boolean);\n};\n\nconst riskFlags =\n  normalizeRisks(invoice.risk_flags);\n\nconst accountingEntryId =\n  `ACC-${invoice.invoice_id}`;\n\nreturn {\n  json: {\n    ...invoice,\n\n    accounting_entry_id:\n      accountingEntryId,\n\n    accounting_total_amount:\n      Math.round(totalAmount * 100) / 100,\n\n    accounting_risk_flags:\n      riskFlags.join(', '),\n\n    accounting_approval_status:\n      'approved',\n\n    accounting_exported_at:\n      new Date().toISOString(),\n\n    status:\n      'accounting_export_pending'\n  }\n};"
      },
