    {
      "parameters": {
        "jsCode": "const invoice = $json;\n\nconst processingId =\n  String(invoice.processing_id || '').trim();\n\nif (!processingId) {\n  throw new Error(\n    'COMPLETION_PROCESSING_ID_MISSING'\n  );\n}\n\nif (invoice.archived !== true) {\n  throw new Error(\n    `COMPLETION_ARCHIVE_REQUIRED: ${processingId}`\n  );\n}\n\nif (invoice.accounting_exported !== true) {\n  throw new Error(\n    `COMPLETION_ACCOUNTING_EXPORT_REQUIRED: ${processingId}`\n  );\n}\n\nconst completedAt =\n  new Date().toISOString();\n\nreturn {\n  json: {\n    ...invoice,\n\n    completion_target_status:\n      'completed',\n\n    completed_at:\n      completedAt,\n  },\n};"
      },
