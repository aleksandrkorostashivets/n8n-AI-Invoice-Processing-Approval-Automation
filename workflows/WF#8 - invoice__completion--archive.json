    {
      "parameters": {
        "jsCode": "const invoice = $json;\n\nconst processingId =\n  String(invoice.processing_id || '').trim();\n\nif (!processingId) {\n  throw new Error(\n    'ARCHIVE_PROCESSING_ID_MISSING'\n  );\n}\n\nlet driveFileId =\n  String(invoice.drive_file_id || '').trim();\n\nif (!driveFileId) {\n  const driveUrl =\n    String(invoice.drive_file_url || '').trim();\n\n  const match =\n    driveUrl.match(/\\/file\\/d\\/([^/]+)/);\n\n  if (match?.[1]) {\n    driveFileId = match[1];\n  }\n}\n\nif (!driveFileId) {\n  throw new Error(\n    `ARCHIVE_DRIVE_FILE_ID_MISSING: ${processingId}`\n  );\n}\n\nconst completionStartedAt =\n  new Date().toISOString();\n\nreturn {\n  json: {\n    ...invoice,\n\n    drive_file_id:\n      driveFileId,\n\n    completion_started_at:\n      completionStartedAt,\n\n    archive_target_folder:\n      '03_Approved',\n\n    status:\n      'archive_pending',\n  },\n};"
      },
