    {
      "parameters": {
        "jsCode": "const prepared =\n  $('invoice__archive--prepare-file').item.json;\n\nconst driveResult = $json;\n\nconst movedFileId =\n  driveResult.id ||\n  prepared.drive_file_id;\n\nif (!movedFileId) {\n  throw new Error(\n    `ARCHIVE_MOVE_RESULT_INVALID: ${prepared.processing_id}`\n  );\n}\n\nconst archivedAt =\n  new Date().toISOString();\n\nreturn {\n  json: {\n    ...prepared,\n\n    status:\n      'archived',\n\n    archived:\n      true,\n\n    drive_file_id:\n      movedFileId,\n\n    drive_file_url:\n      `https://drive.google.com/file/d/${movedFileId}/view`,\n\n    archive_folder:\n      '03_Approved',\n\n    archived_at:\n      archivedAt,\n\n    archive_result: {\n      file_id:\n        movedFileId,\n\n      file_name:\n        driveResult.name ||\n        prepared.storage_file_name ||\n        prepared.file_name ||\n        '',\n\n      mime_type:\n        driveResult.mimeType ||\n        'application/pdf',\n\n      folder:\n        '03_Approved',\n    },\n  },\n};"
      },
      "type": "n8n-nodes-base.code",
