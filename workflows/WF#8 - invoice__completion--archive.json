    {
      "parameters": {
        "jsCode": "const prepared =\n  $('invoice__completion--prepare-registry-update').item.json;\n\nconst sheetResult = $json;\n\nconst processingId =\n  String(prepared.processing_id || '').trim();\n\nif (!processingId) {\n  throw new Error(\n    'COMPLETION_RESULT_PROCESSING_ID_MISSING'\n  );\n}\n\nconst expectedStatus =\n  String(\n    prepared.completion_target_status || ''\n  )\n    .trim()\n    .toLowerCase();\n\nif (expectedStatus !== 'completed') {\n  throw new Error(\n    `COMPLETION_TARGET_STATUS_INVALID: ${expectedStatus || 'missing'}`\n  );\n}\n\nconst returnedStatus =\n  String(sheetResult.status || '')\n    .trim()\n    .toLowerCase();\n\n/*\n * Google Sheets Update Row зазвичай повертає оновлений рядок.\n * Якщо status присутній, перевіряємо його.\n */\nif (\n  returnedStatus &&\n  returnedStatus !== 'completed'\n) {\n  throw new Error(\n    `COMPLETION_REGISTRY_STATUS_MISMATCH: expected completed, received ${returnedStatus}`\n  );\n}\n\nreturn {\n  json: {\n    ...prepared,\n\n    status:\n      'completed',\n\n    processed_at:\n      prepared.completed_at,\n\n    registry_updated:\n      true,\n\n    registry_row_number:\n      sheetResult.row_number ??\n      sheetResult.rowNumber ??\n      prepared.row_number ??\n      null,\n\n    completion_result: {\n      processing_id:\n        processingId,\n\n      accounting_exported:\n        prepared.accounting_exported === true,\n\n      archived:\n        prepared.archived === true,\n\n      archive_folder:\n        prepared.archive_folder,\n\n      registry_status:\n        returnedStatus || 'completed',\n\n      completed_at:\n        prepared.completed_at,\n    },\n  },\n};"
      },
