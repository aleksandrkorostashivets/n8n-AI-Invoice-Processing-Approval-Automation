    {
      "parameters": {
        "jsCode": "const source =\n  $('invoice__gmail--prepare-finalization').first().json;\n\nconst expectedAttachmentCount =\n  Number(source.attachment_count);\n\nconst rawRows =\n  $input.all()\n    .map(item => item.json)\n    .filter(row =>\n      Boolean(\n        String(row.processing_id || '').trim()\n      )\n    );\n\nconst uniqueRowsMap =\n  new Map();\n\nfor (const row of rawRows) {\n  const processingId =\n    String(row.processing_id || '').trim();\n\n  if (!uniqueRowsMap.has(processingId)) {\n    uniqueRowsMap.set(\n      processingId,\n      row\n    );\n  }\n}\n\nconst invoiceRows =\n  [...uniqueRowsMap.values()];\n\nconst acceptedStatuses = [\n  'extracted',\n  'vendor_validated',\n  'duplicate_validated',\n  'validated',\n  'valid',\n  'warning',\n  'manual_review',\n  'manual_review_pending',\n  'manual_review_completed',\n  'approval_pending',\n  'approved',\n  'accounting_export_pending',\n  'accounting_exported',\n  'archive_pending',\n  'archived',\n  'completed',\n  'rejected',\n];\n\nconst incompleteRows =\n  invoiceRows.filter(row => {\n    const status =\n      String(row.status || '')\n        .trim()\n        .toLowerCase();\n\n    return !acceptedStatuses.includes(status);\n  });\n\nconst registeredCount =\n  invoiceRows.length;\n\nconst allAttachmentsRegistered =\n  registeredCount >= expectedAttachmentCount;\n\nconst allRecordsAccepted =\n  allAttachmentsRegistered &&\n  incompleteRows.length === 0;\n\nconst gmailFinalizationReady =\n  allRecordsAccepted;\n\nreturn [\n  {\n    json: {\n      ...source,\n\n      registered_invoice_count:\n        registeredCount,\n\n      expected_attachment_count:\n        expectedAttachmentCount,\n\n      registered_processing_ids:\n        invoiceRows.map(\n          row => row.processing_id\n        ),\n\n      incomplete_processing_ids:\n        incompleteRows.map(\n          row => row.processing_id\n        ),\n\n      all_attachments_registered:\n        allAttachmentsRegistered,\n\n      all_records_accepted:\n        allRecordsAccepted,\n\n      gmail_finalization_ready:\n        gmailFinalizationReady,\n\n      gmail_finalization_evaluated_at:\n        new Date().toISOString(),\n    },\n  },\n];"
      },
