    {
      "parameters": {
        "jsCode": "const input = $json;\n\nconst emailMessageId =\n  String(input.email_message_id || '').trim();\n\nconst processingId =\n  String(input.processing_id || '').trim();\n\nconst attachmentCount =\n  Number(input.attachment_count ?? 1);\n\nif (!emailMessageId) {\n  throw new Error(\n    'GMAIL_FINALIZATION_MESSAGE_ID_MISSING'\n  );\n}\n\nif (!processingId) {\n  throw new Error(\n    `GMAIL_FINALIZATION_PROCESSING_ID_MISSING: ${emailMessageId}`\n  );\n}\n\nif (\n  !Number.isInteger(attachmentCount) ||\n  attachmentCount < 1\n) {\n  throw new Error(\n    `GMAIL_FINALIZATION_ATTACHMENT_COUNT_INVALID: ${attachmentCount}`\n  );\n}\n\nreturn {\n  json: {\n    ...input,\n\n    email_message_id:\n      emailMessageId,\n\n    processing_id:\n      processingId,\n\n    attachment_count:\n      attachmentCount,\n\n    gmail_finalization_started_at:\n      new Date().toISOString(),\n  },\n};"
      },
